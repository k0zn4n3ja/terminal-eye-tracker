#!/usr/bin/env bash
# Toggle the tmux-eyes daemon on/off as a detached background process.
#
# Bind in ~/.tmux.conf, e.g.:
#   bind-key g run-shell "/home/nixdt1/Repos/vectorise/tmux_eye_tracking/bin/tmux-eyes-toggle"
# Then Ctrl-b g toggles it.

set -u

PROJECT_DIR="/home/nixdt1/Repos/vectorise/tmux_eye_tracking"
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}"
PID_FILE="$RUNTIME_DIR/tmux-eyes.pid"
LOG_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/tmux-eyes"
LOG_FILE="$LOG_DIR/daemon.log"

mkdir -p "$LOG_DIR"

notify() {
    if command -v tmux >/dev/null 2>&1 && [ -n "${TMUX:-}" ] || tmux info >/dev/null 2>&1; then
        tmux display-message "$1" 2>/dev/null || true
    fi
    echo "$1"
}

is_running() {
    [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE" 2>/dev/null)" 2>/dev/null
}

stop() {
    local pid
    pid="$(cat "$PID_FILE" 2>/dev/null || echo "")"
    if [ -n "$pid" ]; then
        # Kill the whole process group (setsid put the daemon in its own group).
        kill -TERM "-$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null || true
        for _ in 1 2 3 4 5 6; do
            kill -0 "$pid" 2>/dev/null || break
            sleep 0.1
        done
        kill -KILL "-$pid" 2>/dev/null || true
    fi
    rm -f "$PID_FILE"
    notify "tmux-eyes: stopped"
}

start() {
    cd "$PROJECT_DIR" || { notify "tmux-eyes: project dir missing"; exit 1; }

    # Detach via setsid → new session + process group → survives this script
    # exiting and is killable as one group later.
    setsid bash -c "
        exec nix-shell --run 'exec python -m tmux_eyes' \
            >> '$LOG_FILE' 2>&1 < /dev/null
    " < /dev/null > /dev/null 2>&1 &
    local pid=$!
    disown 2>/dev/null || true
    echo "$pid" > "$PID_FILE"
    notify "tmux-eyes: started (pid $pid, log: $LOG_FILE)"
}

case "${1:-toggle}" in
    start)
        if is_running; then
            notify "tmux-eyes: already running (pid $(cat "$PID_FILE"))"
        else
            start
        fi
        ;;
    stop)
        if is_running; then
            stop
        else
            notify "tmux-eyes: not running"
            rm -f "$PID_FILE"
        fi
        ;;
    status)
        if is_running; then
            echo "running (pid $(cat "$PID_FILE"))"
            exit 0
        else
            echo "stopped"
            exit 1
        fi
        ;;
    toggle|"")
        if is_running; then
            stop
        else
            start
        fi
        ;;
    *)
        echo "usage: $0 [toggle|start|stop|status]" >&2
        exit 2
        ;;
esac
